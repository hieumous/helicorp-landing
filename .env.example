# URL webhook nhận dữ liệu đăng ký (Zapier Catch Hook, Make.com, Discord, ...)
# Để trống khi phát triển: lead sẽ được log ra console thay vì gửi đi.
WEBHOOK_URL=

# Webhook riêng cho analytics (click/scroll/shop). Để trống sẽ dùng WEBHOOK_URL hoặc log console.
ANALYTICS_WEBHOOK_URL=

# Google Gemini API key cho chatbot tư vấn (https://aistudio.google.com/apikey)
# Để trống: chatbot dùng câu trả lời dự phòng theo từ khoá (vẫn demo được).
GEMINI_API_KEY=
# Tùy chọn: đổi model, mặc định gemini-2.0-flash
GEMINI_MODEL=
